# MongoDB Configuration
# For local development: mongodb://localhost:27017/pmo_db
# For production with auth: mongodb://username:password@localhost:27017/pmo_db
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/pmo_db
MONGODB_URI=mongodb://localhost:27017/pmo_db

# Server Configuration
# Port for the Express server (default: 5000)
PORT=5000

# JWT Secret (REQUIRED - Change this in production!)
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-this-in-production

# Node Environment
# Options: development, production
NODE_ENV=development
